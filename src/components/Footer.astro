---
// src/components/Footer.astro
import { siteConfig } from '../utils/siteConfig';
---

<footer class="footer-glass mt-auto">
    <div class="max-w-5xl mx-auto px-6 py-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-10">
        <!-- 关于 -->
        <div class="reveal-target">
          <h3 class="font-display text-sm font-bold text-[var(--text-primary)] mb-4 tracking-wide">{siteConfig.title}</h3>
          <p class="text-sm text-[var(--text-muted)] font-serif leading-relaxed">
            {siteConfig.bio}
          </p>
        </div>

        <!-- 导航 -->
        <div class="reveal-target">
          <h3 class="font-display text-sm font-bold text-[var(--text-primary)] mb-4 tracking-wide">导航</h3>
          <div class="flex flex-col gap-2.5">
            <a href="/home/" class="text-sm text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors font-serif">首页</a>
            <a href="/blog/" class="text-sm text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors font-serif">文章</a>
            <a href="/archive/" class="text-sm text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors font-serif">归档</a>
            <a href="/tools/" class="text-sm text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors font-serif">工具</a>
            <a href="/friends/" class="text-sm text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors font-serif">友链</a>
            <a href="/about/" class="text-sm text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors font-serif">关于</a>
          </div>
        </div>

        <!-- 最近更新 -->
        <div class="reveal-target">
          <h3 class="font-display text-sm font-bold text-[var(--text-primary)] mb-4 tracking-wide">最近更新</h3>
          <div class="flex flex-col gap-3" id="footer-recent">
            <p class="text-sm text-[var(--text-muted)] font-serif">加载中...</p>
          </div>
        </div>

        <!-- 联系 -->
        <div class="reveal-target">
          <h3 class="font-display text-sm font-bold text-[var(--text-primary)] mb-4 tracking-wide">联系</h3>
          <div class="flex flex-col gap-2.5">
            <a href="https://github.com/xxxdkubi" target="_blank" rel="noopener" class="text-sm text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors font-serif">GitHub</a>
            <a href="/rss.xml" target="_blank" class="text-sm text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors font-serif">RSS 订阅</a>
          </div>
        </div>
      </div>

      <!-- 底部 -->
      <div class="pt-6 border-t border-[var(--border)]/20 flex flex-col md:flex-row items-center justify-between gap-3 text-xs text-[var(--text-muted)]/60 reveal-target">
        <p class="font-serif">&copy; {new Date().getFullYear()} {siteConfig.author} · {siteConfig.title}</p>
        <div class="flex items-center gap-4 font-serif">
          <span>访客 <span id="busuanzi_value_site_uv" class="font-mono text-[var(--text-muted)]">-</span></span>
          <span>·</span>
          <span>修行路上</span>
        </div>
      </div>
    </div>
  </div>
  <script async src="https://busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>
</footer>

<script>
  document.addEventListener('astro:page-load', async () => {
    const container = document.getElementById('footer-recent');
    if (!container) return;
    try {
      const resp = await fetch('/blog/index.json');
      const posts = await resp.json();
      container.innerHTML = posts.slice(0, 3)
        .map((p: any) => `
          <a href="/blog/${p.slug}/" class="group/post">
            <p class="text-sm text-[var(--text-muted)] group-hover/post:text-[var(--accent)] transition-colors font-serif line-clamp-1">${p.title}</p>
            <p class="text-[11px] text-[var(--text-muted)]/50 font-serif mt-0.5">${p.date}</p>
          </a>
        `).join('');
    } catch {
      container.innerHTML = '<p class="text-sm text-[var(--text-muted)] font-serif">暂无更新</p>';
    }
  });
</script>
