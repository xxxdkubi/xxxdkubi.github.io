---
// src/components/MusicPlayer.astro
---

<div id="music-player" class="music-player" aria-label="音乐播放器">
  <!-- 展开面板 -->
  <div class="music-panel" id="music-panel">
    <div class="music-panel-inner">
      <span class="music-now-playing" id="music-label">雨声</span>
      <div class="music-controls">
        <button class="music-btn" id="music-prev" aria-label="上一首">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 20L9 12l10-8v16zM5 19V5"></path>
          </svg>
        </button>
        <button class="music-btn music-btn-play" id="music-toggle" aria-label="播放">
          <svg id="music-icon-play" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <svg id="music-icon-pause" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </button>
        <button class="music-btn" id="music-next" aria-label="下一首">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 4l10 8-10 8V4zM19 5v14"></path>
          </svg>
        </button>
      </div>
      <div class="music-tracks" id="music-tracks">
        <button class="music-track" data-index="0" data-name="雨声">
          <span>🌧</span><span>雨声</span>
        </button>
        <button class="music-track" data-index="1" data-name="溪流">
          <span>💧</span><span>溪流</span>
        </button>
        <button class="music-track" data-index="2" data-name="夜林">
          <span>🌲</span><span>夜林</span>
        </button>
      </div>
    </div>
  </div>
  <!-- 浮动按钮 -->
  <button class="music-trigger" id="music-trigger" aria-label="音乐">
    <svg class="w-5 h-5 music-trigger-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"></path>
    </svg>
  </button>
</div>
<audio id="music-audio" preload="none" loop></audio>

<script>
  function initMusicPlayer() {
    const audio = document.getElementById('music-audio') as HTMLAudioElement;
    const panel = document.getElementById('music-panel');
    const trigger = document.getElementById('music-trigger');
    const toggle = document.getElementById('music-toggle');
    const prev = document.getElementById('music-prev');
    const next = document.getElementById('music-next');
    const label = document.getElementById('music-label');
    const iconPlay = document.getElementById('music-icon-play');
    const iconPause = document.getElementById('music-icon-pause');
    const trackBtns = document.querySelectorAll('.music-track');
    if (!audio || !panel || !trigger) return;

    const tracks = ['/music/rain.wav', '/music/stream.wav', '/music/forest.wav'];
    const names = ['雨声', '溪流', '夜林'];
    let currentIndex = 0;

    function updateUI() {
      if (label) label.textContent = names[currentIndex];
      trackBtns.forEach((t, i) => t.classList.toggle('is-active', i === currentIndex));
      if (!audio.paused) {
        iconPlay?.classList.add('hidden');
        iconPause?.classList.remove('hidden');
        trigger.classList.add('is-playing');
      } else {
        iconPlay?.classList.remove('hidden');
        iconPause?.classList.add('hidden');
        trigger.classList.remove('is-playing');
      }
    }

    trigger.addEventListener('click', () => panel.classList.toggle('is-open'));
    toggle?.addEventListener('click', (e) => { e.stopPropagation(); audio.paused ? audio.play().catch(()=>{}) : audio.pause(); updateUI(); });
    next?.addEventListener('click', (e) => { e.stopPropagation(); currentIndex = (currentIndex + 1) % tracks.length; audio.src = tracks[currentIndex]; audio.play().catch(()=>{}); updateUI(); });
    prev?.addEventListener('click', (e) => { e.stopPropagation(); currentIndex = (currentIndex - 1 + tracks.length) % tracks.length; audio.src = tracks[currentIndex]; audio.play().catch(()=>{}); updateUI(); });
    trackBtns.forEach((btn, i) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        currentIndex = i;
        audio.src = tracks[i];
        audio.play().catch(()=>{});
        updateUI();
      });
    });
    audio.addEventListener('play', updateUI);
    audio.addEventListener('pause', updateUI);
    audio.addEventListener('ended', () => { currentIndex = (currentIndex + 1) % tracks.length; audio.src = tracks[currentIndex]; audio.play().catch(()=>{}); updateUI(); });
  }
  document.addEventListener('astro:page-load', initMusicPlayer);
  initMusicPlayer();
</script>
