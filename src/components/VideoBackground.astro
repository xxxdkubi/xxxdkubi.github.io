---
// src/components/VideoBackground.astro — 视频壁纸 + 全局毛玻璃样式
---
<div id="video-bg-container" class="video-bg-container">
  <div class="video-bg-wallpaper"></div>
  <video id="bg-video" preload="none" muted playsinline class="video-bg-video"></video>
  <div class="video-bg-overlay"></div>
</div>

<style is:global>
  /* ==================== 背景层 ==================== */
  .video-bg-container{position:fixed;inset:0;z-index:-100;pointer-events:none}
  .video-bg-wallpaper{position:absolute;inset:0;background:url('/maple.jpg') center/cover no-repeat}
  .video-bg-video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0;transition:opacity .6s ease}
  .video-bg-video.is-loaded{opacity:1}
  .video-bg-video.is-fading{opacity:0;transition:opacity 1.2s cubic-bezier(.16,1,.3,1)}
  .video-bg-overlay{position:absolute;inset:0;background:rgba(0,0,0,.5);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px)}
  :root:not(.dark) .video-bg-overlay{background:rgba(0,0,0,.35);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px)}

  /* ==================== 导航栏 - 透明毛玻璃 ==================== */
  .header-glass{position:sticky;top:0;z-index:40;width:100%}
  .header-glass-inner{margin:8px auto 0;max-width:64rem;border-radius:16px;
    background:rgba(255,255,255,.06);backdrop-filter:blur(24px) saturate(140%);-webkit-backdrop-filter:blur(24px) saturate(140%);
    border:1px solid rgba(255,255,255,.10);
    box-shadow:0 4px 24px rgba(0,0,0,.15);
    transition:all .5s cubic-bezier(.16,1,.3,1);
  }
  .dark .header-glass-inner{background:rgba(15,18,15,.45);border-color:rgba(255,255,255,.07)}
  .header-nav{display:flex;align-items:center;justify-content:space-between;padding:0 16px;height:50px}
  @media(min-width:768px){.header-nav{padding:0 24px}}
  .header-logo{font-family:'PingFang SC','Hiragino Sans GB','Microsoft YaHei',sans-serif;font-size:1.1rem;font-weight:700;
    color:var(--text-primary);transition:all .4s cubic-bezier(.16,1,.3,1)}
  .header-logo:hover{color:var(--accent);filter:brightness(1.1)}
  .header-links{display:none;align-items:center;gap:2px;
    background:rgba(255,255,255,.04);border-radius:999px;padding:3px;
    border:1px solid rgba(255,255,255,.06);}
  @media(min-width:768px){.header-links{display:flex}}
  .header-link{border-radius:999px;padding:6px 14px;font-size:.82rem;font-weight:500;
    color:var(--text-secondary);transition:all .35s cubic-bezier(.16,1,.3,1)}
  .header-link:hover{background:rgba(255,255,255,.10);color:var(--text-primary);box-shadow:0 0 12px rgba(255,255,255,.04)}
  .header-link-active{background:rgba(255,255,255,.12);color:var(--text-primary);box-shadow:0 0 8px rgba(255,255,255,.04)}
  .header-actions{display:flex;align-items:center;gap:4px}
  .header-icon-btn{width:34px;height:34px;display:flex;align-items:center;justify-content:center;border-radius:10px;
    color:var(--text-secondary);transition:all .3s cubic-bezier(.16,1,.3,1)}
  .header-icon-btn:hover{color:var(--accent);background:rgba(255,255,255,.08);box-shadow:0 0 12px rgba(255,255,255,.04)}

  /* Mobile */
  .mobile-menu{display:none;border-top:1px solid rgba(255,255,255,.08);padding:8px 16px 12px;
    background:rgba(15,18,15,.85);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-radius:0 0 16px 16px}
  .mobile-menu:not(.hidden){display:flex;flex-direction:column;gap:2px}
  .mobile-link{padding:10px 12px;border-radius:10px;font-size:.88rem;
    color:var(--text-secondary);transition:all .25s ease}
  .mobile-link:hover{background:rgba(255,255,255,.08);color:var(--text-primary)}
  .mobile-link-active{background:rgba(255,255,255,.10);color:var(--accent)}

  /* ==================== 卡片 - 透明毛玻璃 ==================== */
  .card,.card-flat,.glass-card{
    background:rgba(255,255,255,.05);backdrop-filter:blur(20px) saturate(140%);-webkit-backdrop-filter:blur(20px) saturate(140%);
    border:1px solid rgba(255,255,255,.08);border-radius:14px;
    box-shadow:0 4px 20px rgba(0,0,0,.15),inset 0 0 0 1px rgba(255,255,255,.03);
    transition:all .5s cubic-bezier(.16,1,.3,1);position:relative;overflow:hidden}
  .dark .card,.dark .card-flat{background:rgba(18,20,16,.40);border-color:rgba(255,255,255,.06)}
  .card:hover,.card-flat:hover{background:rgba(255,255,255,.09);border-color:rgba(255,255,255,.15);
    box-shadow:0 8px 32px rgba(0,0,0,.25),inset 0 0 0 1px rgba(255,255,255,.04);transform:translateY(-2px)}
  .dark .card:hover,.dark .card-flat:hover{background:rgba(20,22,18,.55);border-color:rgba(255,255,255,.12)}

  /* 鼠标跟随光晕 */
  .card::before,.card-flat::before,.glass-card::before{
    content:'';position:absolute;inset:0;z-index:3;pointer-events:none;border-radius:inherit;
    background:radial-gradient(400px circle at var(--mouse-x,50%) var(--mouse-y,50%),
      rgba(200,220,250,.10) 0%,rgba(160,190,225,.04) 30%,transparent 70%);
    opacity:0;transition:opacity .25s ease}
  .card:hover::before,.card-flat:hover::before,.glass-card:hover::before{opacity:1}

  /* ==================== 透明 Footer ==================== */
  .footer-glass{border-top:1px solid rgba(255,255,255,.06);
    background:rgba(255,255,255,.03);backdrop-filter:blur(20px) saturate(140%);-webkit-backdrop-filter:blur(20px) saturate(140%)}
  .dark .footer-glass{background:rgba(15,18,15,.30)}

  /* ==================== 分隔线 ==================== */
  .glass-divider{height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,.08) 20%,rgba(255,255,255,.08) 80%,transparent)}

  /* ==================== 音乐播放器玻璃化 ==================== */
  .music-trigger{background:rgba(255,255,255,.06)!important;backdrop-filter:blur(16px)!important;-webkit-backdrop-filter:blur(16px)!important;
    border-color:rgba(255,255,255,.10)!important}
  .music-panel{background:rgba(15,18,15,.88)!important;backdrop-filter:blur(24px)!important;-webkit-backdrop-filter:blur(24px)!important;
    border-color:rgba(255,255,255,.08)!important}

  /* ==================== 入口页按钮 ==================== */
  .entrance-btn-glass{border:1.5px solid rgba(255,255,255,.15)!important;
    background:rgba(255,255,255,.06)!important;backdrop-filter:blur(16px)!important;-webkit-backdrop-filter:blur(16px)!important;
    color:var(--text-primary)!important}
  .entrance-btn-glass:hover{background:rgba(255,255,255,.12)!important;border-color:var(--accent)!important;color:var(--accent)!important}

  /* ==================== 主题切换按钮 ==================== */
  #theme-toggle{background:rgba(255,255,255,.06);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);
    border:1px solid rgba(255,255,255,.08);border-radius:12px}
</style>

<script>
  // 视频延迟加载（仅客户端）
  (function(){"use strict";
  function initVideo(){var v=document.getElementById('bg-video');if(!v)return;
    var p=sessionStorage.getItem('bg-video-played');v.src='/maple.mp4';
    function play(){if(p){v.style.display='none';return}v.classList.add('is-loaded');v.play().catch(function(){});
      setTimeout(function(){v.classList.add('is-fading');sessionStorage.setItem('bg-video-played','1')},2000)}
    v.addEventListener('canplay',play);v.addEventListener('loadeddata',function(){if(v.readyState>=3&&!p)play()})}
  if('requestIdleCallback' in window)requestIdleCallback(initVideo);else setTimeout(initVideo,200);

  // 毛玻璃鼠标跟踪
  function initGlassTracking(){document.addEventListener('mousemove',function(e){
    document.querySelectorAll('.card,.card-flat,.glass-card,.header-glass-inner').forEach(function(c){
      var r=c.getBoundingClientRect(),mx=e.clientX,my=e.clientY;
      if(mx>=r.left-60&&mx<=r.right+60&&my>=r.top-60&&my<=r.bottom+60){
        c.style.setProperty('--mouse-x',((mx-r.left)/r.width*100)+'%');
        c.style.setProperty('--mouse-y',((my-r.top)/r.height*100)+'%')}})})}
  document.addEventListener('astro:page-load',initGlassTracking);initGlassTracking()
  })();
</script>
