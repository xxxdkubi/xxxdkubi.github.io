---
// src/pages/tools.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="工具">
  <div class="max-w-4xl mx-auto px-6 py-12">
    <div class="mb-10">
      <h1 class="font-display text-2xl font-bold text-[var(--text-primary)] mb-2">工具</h1>
      <p class="text-sm text-[var(--text-muted)] font-serif">实用工具合集，助力高效开发</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Terminal -->
      <a href="https://fishshell.com/" target="_blank" rel="noopener" class="card-flat p-6 group reveal-target">
        <h3 class="font-display text-lg font-bold text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors">🐟 Fish Shell</h3>
        <p class="mt-2 text-sm text-[var(--text-secondary)] leading-relaxed">比 zsh 更友好的终端 shell，开箱即用，不需要折腾配置。</p>
        <span class="mt-3 text-xs text-[var(--accent)]/60 font-mono">终端</span>
      </a>

      <!-- VS Code -->
      <a href="/blog/vscode-productivity/" class="card-flat p-6 group reveal-target">
        <h3 class="font-display text-lg font-bold text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors">📝 VS Code 效率指南</h3>
        <p class="mt-2 text-sm text-[var(--text-secondary)] leading-relaxed">从快捷键到插件配置，一份面向日常开发的实用技巧合集。</p>
        <span class="mt-3 text-xs text-[var(--accent)]/60 font-mono">编辑器</span>
      </a>

      <!-- Git -->
      <a href="/blog/git-tips/" class="card-flat p-6 group reveal-target">
        <h3 class="font-display text-lg font-bold text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors">🔧 Git 实用技巧</h3>
        <p class="mt-2 text-sm text-[var(--text-secondary)] leading-relaxed">日常开发中最常用的 Git 技巧，从撤销操作到分支管理。</p>
        <span class="mt-3 text-xs text-[var(--accent)]/60 font-mono">版本控制</span>
      </a>

      <!-- Markdown -->
      <a href="/blog/markdown-guide/" class="card-flat p-6 group reveal-target">
        <h3 class="font-display text-lg font-bold text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors">📄 Markdown 写作指南</h3>
        <p class="mt-2 text-sm text-[var(--text-secondary)] leading-relaxed">如何使用 Markdown 进行高效写作的实用指南。</p>
        <span class="mt-3 text-xs text-[var(--accent)]/60 font-mono">写作</span>
      </a>
    </div>
  </div>
</Layout>
