---
// src/pages/tags/index.astro
import Layout from '../../layouts/Layout.astro';
---

<Layout title="标签">
  <div class="max-w-4xl mx-auto px-6 py-12">
    <div class="mb-10">
      <h1 class="font-display text-2xl font-bold text-[var(--text-primary)] mb-2">标签</h1>
      <p class="text-sm text-[var(--text-muted)] font-serif">按话题浏览文章</p>
    </div>
    <div id="tags-content">
      <div class="text-center py-12 text-sm text-[var(--text-muted)]/50 font-serif">加载中...</div>
    </div>
  </div>
</Layout>

<script>
  document.addEventListener('astro:page-load', async () => {
    const container = document.getElementById('tags-content');
    if (!container) return;
    try {
      const resp = await fetch('/blog/index.json');
      const posts = await resp.json();
      const tagMap: Record<string, any[]> = {};
      posts.forEach((p: any) => {
        if (p.tags) p.tags.forEach((t: string) => {
          if (!tagMap[t]) tagMap[t] = [];
          tagMap[t].push(p);
        });
      });
      const tags = Object.entries(tagMap).sort((a, b) => b[1].length - a[1].length);
      container.innerHTML = `
        <div class="flex flex-wrap gap-3 mb-10">
          ${tags.map(([tag, pts]: any, i: number) => `
            <a href="/tags/${tag}/" class="card px-4 py-2 text-sm font-serif text-[var(--text-secondary)] hover:text-[var(--accent)] hover:border-[var(--accent)] transition-all duration-300 reveal-target opacity-0 translate-y-4"
               style="transition: opacity 0.5s ${i * 0.03}s, transform 0.5s ${i * 0.03}s cubic-bezier(0.16,1,0.3,1)">
              ${tag} <span class="text-[var(--text-muted)]/50 ml-1">${pts.length}</span>
            </a>
          `).join('')}
        </div>
      `;
      setTimeout(() => {
        container.querySelectorAll('.reveal-target').forEach(el => el.classList.add('is-visible'));
      }, 100);
    } catch {
      container.innerHTML = '<div class="text-center py-12 text-sm text-[var(--text-muted)]/50 font-serif">加载失败</div>';
    }
  });
</script>
