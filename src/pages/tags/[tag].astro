---
// src/pages/tags/[tag].astro
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const allTags = new Set<string>();
  posts.forEach(p => (p.data.tags || []).forEach((t: string) => allTags.add(t)));
  return [...allTags].map(tag => ({ params: { tag }, props: { tag } }));
}

const { tag } = Astro.props;
---

<Layout title={`标签：${tag}`}>
  <div class="max-w-4xl mx-auto px-6 py-12">
    <div class="mb-10">
      <a href="/tags/" class="text-sm text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors font-serif mb-3 inline-block">&larr; 所有标签</a>
      <h1 class="font-display text-2xl font-bold text-[var(--text-primary)]">标签：<span class="text-[var(--accent)]">{tag}</span></h1>
    </div>
    <div id="tag-posts" class="space-y-4">
      <div class="text-center py-12 text-sm text-[var(--text-muted)]/50 font-serif">加载中...</div>
    </div>
  </div>
</Layout>

<script>
  document.addEventListener('astro:page-load', async () => {
    const container = document.getElementById('tag-posts');
    if (!container) return;
    const currentTag = decodeURIComponent(window.location.pathname.replace('/tags/', '').replace(/\/$/, ''));
    try {
      const resp = await fetch('/blog/index.json');
      const posts = (await resp.json()).filter((p: any) => p.tags && p.tags.includes(currentTag));
      if (posts.length === 0) {
        container.innerHTML = '<div class="text-center py-12 text-sm text-[var(--text-muted)]/50 font-serif">暂无相关文章</div>';
        return;
      }
      container.innerHTML = posts.map((post: any, i: number) => `
        <a href="/blog/${post.slug}/" class="block group card-flat p-5 reveal-target opacity-0 translate-y-4"
           style="transition: opacity 0.7s ${i * 0.05}s, transform 0.7s ${i * 0.05}s cubic-bezier(0.16,1,0.3,1)">
          <div class="flex items-center gap-3 mb-2">
            <time class="text-xs font-mono text-[var(--text-muted)]/60">${post.date}</time>
            ${post.category ? `<span class="text-[10px] text-[var(--accent)]/70 font-mono">[${post.category}]</span>` : ''}
          </div>
          <h2 class="font-display text-base font-bold text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors">${post.title}</h2>
          <p class="mt-1 text-sm text-[var(--text-secondary)] line-clamp-2">${post.description || ''}</p>
        </a>
      `).join('');
      setTimeout(() => {
        container.querySelectorAll('.reveal-target').forEach(el => el.classList.add('is-visible'));
      }, 100);
    } catch {
      container.innerHTML = '<div class="text-center py-12 text-sm text-[var(--text-muted)]/50 font-serif">加载失败</div>';
    }
  });
</script>
