---
// src/pages/archive.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="归档">
  <div class="max-w-4xl mx-auto px-6 py-12">
    <div class="mb-10">
      <h1 class="font-display text-2xl font-bold text-[var(--text-primary)] mb-2">归档</h1>
      <p class="text-sm text-[var(--text-muted)] font-serif">所有文章按时间排列</p>
    </div>
    <div id="archive-content">
      <div class="text-center py-12 text-sm text-[var(--text-muted)]/50 font-serif">加载中...</div>
    </div>
  </div>
</Layout>

<script>
  document.addEventListener('astro:page-load', async () => {
    const container = document.getElementById('archive-content');
    if (!container) return;
    try {
      const resp = await fetch('/blog/index.json');
      const posts = await resp.json();
      if (posts.length === 0) {
        container.innerHTML = '<div class="text-center py-12 text-sm text-[var(--text-muted)]/50 font-serif">暂无文章</div>';
        return;
      }
      // Group by year
      const grouped: Record<string, any[]> = {};
      posts.forEach((p: any) => {
        const year = p.date.slice(0, 4);
        if (!grouped[year]) grouped[year] = [];
        grouped[year].push(p);
      });
      const years = Object.keys(grouped).sort((a, b) => b.localeCompare(a));
      container.innerHTML = years.map((year, yi) => `
        <div class="mb-10 reveal-target opacity-0 translate-y-4" style="transition: opacity 0.7s ${yi * 0.1}s cubic-bezier(0.16,1,0.3,1), transform 0.7s ${yi * 0.1}s cubic-bezier(0.16,1,0.3,1)">
          <h2 class="font-display text-4xl font-bold text-[var(--text-primary)]/20 mb-4">${year}</h2>
          <p class="text-xs text-[var(--text-muted)] mb-4 font-serif">${grouped[year].length} 篇文章</p>
          <div class="space-y-1 ml-4 border-l-2 border-[var(--border)] pl-6">
            ${grouped[year].map((p: any) => `
              <a href="/blog/${p.slug}/" class="block py-1.5 group hover:bg-[var(--bg)]/50 rounded px-3 -mx-3 transition-all">
                <div class="flex items-center gap-3 flex-wrap">
                  <time class="text-xs font-mono text-[var(--text-muted)]/60 w-16 shrink-0">${p.date.slice(5)}</time>
                  ${p.category ? `<span class="text-[10px] text-[var(--accent)]/70 font-mono">[${p.category}]</span>` : ''}
                  <span class="text-sm text-[var(--text-secondary)] group-hover:text-[var(--accent)] transition-colors font-serif">${p.title}</span>
                </div>
              </a>
            `).join('')}
          </div>
        </div>
      `).join('');
      setTimeout(() => {
        container.querySelectorAll('.reveal-target').forEach(el => el.classList.add('is-visible'));
      }, 100);
    } catch {
      container.innerHTML = '<div class="text-center py-12 text-sm text-[var(--text-muted)]/50 font-serif">加载失败</div>';
    }
  });
</script>
