---
// src/pages/friends.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="友链">
  <div class="max-w-4xl mx-auto px-6 py-12">
    <div class="mb-10">
      <h1 class="font-display text-2xl font-bold text-[var(--text-primary)] mb-2">友链</h1>
      <p class="text-sm text-[var(--text-muted)] font-serif">有朋自远方来，不亦乐乎。</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="card-flat p-5 reveal-target">
        <h3 class="font-display text-sm font-bold text-[var(--text-primary)]">友链虚位以待</h3>
        <p class="mt-1 text-xs text-[var(--text-muted)] font-serif">欢迎交换友链，联系 GitHub 或留言。</p>
      </div>
    </div>
  </div>
</Layout>
