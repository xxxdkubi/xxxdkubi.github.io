---
// src/pages/guestbook.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="留言">
  <div class="max-w-3xl mx-auto px-6 py-12">
    <div class="mb-10">
      <h1 class="font-display text-2xl font-bold text-[var(--text-primary)] mb-2">留言</h1>
      <p class="text-sm text-[var(--text-muted)] font-serif">有话说？请在此留言。</p>
    </div>

    <div class="card p-8 text-center reveal-target">
      <p class="font-display text-lg text-[var(--text-secondary)] mb-4">
        留言功能即将上线
      </p>
      <p class="text-sm text-[var(--text-muted)] font-serif">
        现阶段欢迎通过 <a href="https://github.com/xxxdkubi" class="text-[var(--accent)] hover:text-[var(--accent-hover)]">GitHub Issues</a> 留言交流
      </p>
    </div>
  </div>
</Layout>
