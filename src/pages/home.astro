---
// src/pages/home.astro
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../utils/siteConfig';
---

<Layout title="首页" description={siteConfig.description}>
  <div>
    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-6 py-14 md:py-20 reveal-target">
      <div class="text-center">
        <p class="font-mono text-xs tracking-[0.2em] text-[var(--text-muted)] uppercase mb-4">
          AI tools / honest notes / useful experiments
        </p>
        <h1 class="font-display text-3xl md:text-4xl font-bold text-[var(--text-primary)] mb-6 leading-snug">
          {siteConfig.title}
        </h1>
        <p class="font-serif text-base md:text-lg text-[var(--text-secondary)] max-w-xl mx-auto leading-relaxed">
          {siteConfig.bio}
        </p>
        <p class="font-serif text-sm text-[var(--text-muted)] mt-4 max-w-lg mx-auto leading-relaxed">
          我不装专家，只记录自己怎么靠一点执行力，把想法变成博客、工具和可复用的方法。
        </p>
      </div>

      <!-- Quick links -->
      <div class="flex flex-wrap justify-center gap-4 mt-10 reveal-target">
        <a href="/tools/" class="card px-6 py-4 font-display text-sm font-medium text-[var(--text-primary)] hover:text-[var(--accent)] hover:border-[var(--accent)] transition-all duration-300 hover:-translate-y-0.5">
          🛠 AI 工具
        </a>
        <a href="/tools/" class="card px-6 py-4 font-display text-sm font-medium text-[var(--text-primary)] hover:text-[var(--accent)] hover:border-[var(--accent)] transition-all duration-300 hover:-translate-y-0.5">
          🧰 实用工具箱
        </a>
        <a href="/blog/" class="card px-6 py-4 font-display text-sm font-medium text-[var(--text-primary)] hover:text-[var(--accent)] hover:border-[var(--accent)] transition-all duration-300 hover:-translate-y-0.5">
          📝 成长日志
        </a>
      </div>

      <div class="text-center mt-8 reveal-target">
        <a href="/blog/" class="inline-flex items-center gap-2 text-sm text-[var(--accent)] hover:text-[var(--accent-hover)] font-serif transition-colors">
          开始阅读
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </section>

    <!-- Separator -->
    <div class="max-w-4xl mx-auto px-6">
      <div class="glass-divider"></div>
    </div>

    <!-- Latest Posts -->
    <section class="max-w-4xl mx-auto px-6 py-14 reveal-target">
      <div class="flex items-center justify-between mb-8">
        <h2 class="section-kicker">最新文章</h2>
        <a href="/blog/" class="text-xs text-[var(--accent)] hover:text-[var(--accent-hover)] transition-colors font-serif">
          查看全部 &rarr;
        </a>
      </div>
      <div id="latest-posts-grid" class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="col-span-3 text-center py-8 text-sm text-[var(--text-muted)]/50 font-serif">加载中...</div>
      </div>
    </section>

    <!-- Separator -->
    <div class="max-w-4xl mx-auto px-6">
      <div class="glass-divider"></div>
    </div>

    <!-- Daily Quote -->
    <section class="max-w-4xl mx-auto px-6 py-14 reveal-target">
      <div class="card p-8 text-center max-w-2xl mx-auto">
        <p id="daily-quote-text" class="font-display text-lg text-[var(--text-primary)] leading-relaxed">「博学之，审问之，慎思之，明辨之，笃行之。」</p>
        <p id="daily-quote-author" class="mt-3 text-sm text-[var(--text-muted)] font-serif">— 《中庸》</p>
      </div>
    </section>
  </div>
</Layout>

<script>
  // Load latest posts
  document.addEventListener('astro:page-load', async () => {
    const grid = document.getElementById('latest-posts-grid');
    if (!grid) return;
    try {
      const resp = await fetch('/blog/index.json');
      const posts = await resp.json();
      const latest = posts.slice(0, 6);
      grid.innerHTML = latest.map((post: any) => `
        <a href="/blog/${post.slug}/" class="group block card-flat p-5 reveal-target opacity-0 translate-y-4"
           style="transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1)">
          <div class="flex items-center gap-2 mb-2">
            ${post.category ? `<span class="text-[11px] font-mono text-[var(--accent)] bg-[rgba(226,168,76,0.08)] px-2 py-0.5 rounded-full">${post.category}</span>` : ''}
          </div>
          <h3 class="font-display text-base font-bold text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors duration-200 leading-snug line-clamp-2">
            ${post.title}
          </h3>
          <p class="mt-1.5 text-sm text-[var(--text-secondary)] line-clamp-2 leading-relaxed">
            ${post.description || ''}
          </p>
          <time class="mt-3 text-xs text-[var(--text-muted)]/60 font-mono block">${post.date}</time>
        </a>
      `).join('');
      // trigger reveal
      setTimeout(() => {
        grid.querySelectorAll('.reveal-target').forEach(el => el.classList.add('is-visible'));
      }, 100);
    } catch {
      grid.innerHTML = '<div class="col-span-3 text-center py-8 text-sm text-[var(--text-muted)]/50 font-serif">暂无文章</div>';
    }

    // Daily quote
    const quotes = [
      { text: '博学之，审问之，慎思之，明辨之，笃行之。', author: '《中庸》' },
      { text: '路漫漫其修远兮，吾将上下而求索。', author: '屈原' },
      { text: '学而不思则罔，思而不学则殆。', author: '孔子' },
      { text: '千里之行，始于足下。', author: '老子' },
      { text: '知之者不如好之者，好之者不如乐之者。', author: '孔子' },
      { text: '不积跬步，无以至千里。', author: '荀子' },
      { text: '业精于勤，荒于嬉；行成于思，毁于随。', author: '韩愈' },
      { text: '三人行，必有我师焉。', author: '孔子' },
      { text: '天行健，君子以自强不息。', author: '《周易》' },
      { text: '纸上得来终觉浅，绝知此事要躬行。', author: '陆游' },
      { text: '读书破万卷，下笔如有神。', author: '杜甫' },
      { text: '宝剑锋从磨砺出，梅花香自苦寒来。', author: '《警世贤文》' },
      { text: '世上无难事，只怕有心人。', author: '谚语' },
      { text: '黑发不知勤学早，白首方悔读书迟。', author: '颜真卿' },
      { text: '少年易老学难成，一寸光阴不可轻。', author: '朱熹' },
    ];
    const dayIndex = new Date().getDate() % quotes.length;
    const q = quotes[dayIndex];
    const quoteEl = document.getElementById('daily-quote-text');
    const authorEl = document.getElementById('daily-quote-author');
    if (quoteEl) quoteEl.textContent = `「${q.text}」`;
    if (authorEl) authorEl.textContent = `— ${q.author}`;
  });
</script>
