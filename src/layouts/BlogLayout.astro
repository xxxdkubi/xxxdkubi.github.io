---
// src/layouts/BlogLayout.astro
import { siteConfig } from '../utils/siteConfig';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MusicPlayer from '../components/MusicPlayer.astro';
import BackToTop from '../components/BackToTop.astro';
import '../styles/global.css';

const { title, description, date, category, tags = [] } = Astro.props;
const fullTitle = title ? `${title} | ${siteConfig.title}` : siteConfig.title;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description || siteConfig.description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description || siteConfig.description} />
    <meta property="og:type" content="article" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <article class="max-w-3xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
        <header class="mb-8">
          {category && (
            <a href={`/category/${category}/`} class="inline-block text-xs font-mono text-[var(--accent)] bg-[rgba(226,168,76,0.08)] px-2.5 py-1 rounded-full mb-3 hover:bg-[rgba(226,168,76,0.15)] transition-colors">
              {category}
            </a>
          )}
          <h1 class="font-display text-2xl sm:text-3xl font-bold text-[var(--text-primary)] leading-snug">{title}</h1>
          {date && (
            <time class="block mt-3 text-sm text-[var(--text-muted)] font-mono" datetime={new Date(date).toISOString()}>
              {new Date(date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          )}
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
              {tags.map((tag: string) => (
                <a href={`/tags/${tag}/`} class="text-xs text-[var(--text-secondary)] bg-[var(--bg)] border border-[var(--border)] px-2.5 py-1 rounded-full hover:text-[var(--accent)] hover:border-[var(--accent)] transition-colors font-serif">
                  {tag}
                </a>
              ))}
            </div>
          )}
        </header>
        <div class="prose">
          <slot />
        </div>
      </article>
    </main>
    <Footer />
    <BackToTop />
    <MusicPlayer />
  </body>
</html>
